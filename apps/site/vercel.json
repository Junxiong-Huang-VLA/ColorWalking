{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/download/app\\.apk$",
      "status": 302,
      "headers": {
        "Location": "https://expo.dev/artifacts/eas/aHsx6DiGxsghtUM1nAyqaU.apk",
        "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0"
      }
    },
    {
      "src": "^/downloads/colorwalking-latest\\.apk$",
      "status": 302,
      "headers": {
        "Location": "https://expo.dev/artifacts/eas/aHsx6DiGxsghtUM1nAyqaU.apk",
        "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0"
      }
    },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}

